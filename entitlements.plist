<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Hardened Runtime entitlements for MeetingNotifier.

  Required for py2app-style bundles to pass notarization:
    allow-unsigned-executable-memory   — py2app's embedded interpreter writes
                                          bytecode to memory pages that are
                                          executed without re-signing

  NOTE: com.apple.security.cs.disable-library-validation was REMOVED (L3).
  build.sh signs every nested .so/.dylib and the embedded Python framework
  with the same Developer ID as the outer bundle, which is exactly what
  library validation permits (same-team + Apple) — so the entitlement was
  unnecessary, and dropping it stops same-user malware from loading an
  unsigned/foreign .dylib into this Calendar-TCC-privileged process.
  If a future build fails to launch with a "code signature ... library
  validation" / "not valid for use in process" error in Console, it means
  some bundled lib is NOT covered by build.sh's signing sweep — fix the
  signing step rather than re-adding this entitlement.
-->
<plist version="1.0">
<dict>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!--
      Calendar data-class entitlement. Traditionally a sandboxed-app thing,
      but macOS 26 (Tahoe) appears to also require it on non-sandboxed apps
      requesting Calendar access via EventKit. Without it, tccd refuses to
      surface the permission dialog (silent denial with promptPolicy=4 in
      the system log; -[TCCDAccessIdentity matchesCodeRequirement:] fails
      with -67050).
    -->
    <key>com.apple.security.personal-information.calendars</key>
    <true/>
</dict>
</plist>
