<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Hardened Runtime entitlements for MeetingNotifier.

  Required for py2app-style bundles to pass notarization:
    allow-unsigned-executable-memory   — py2app's embedded interpreter writes
                                          bytecode to memory pages that are
                                          executed without re-signing
    disable-library-validation         — lets the bundle load the bundled
                                          Python framework, PyObjC, etc. even
                                          though they aren't signed by Apple
-->
<plist version="1.0">
<dict>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <!--
      Calendar data-class entitlement. Traditionally a sandboxed-app thing,
      but macOS 26 (Tahoe) appears to also require it on non-sandboxed apps
      requesting Calendar access via EventKit. Without it, tccd refuses to
      surface the permission dialog (silent denial with promptPolicy=4 in
      the system log; -[TCCDAccessIdentity matchesCodeRequirement:] fails
      with -67050).
    -->
    <key>com.apple.security.personal-information.calendars</key>
    <true/>
</dict>
</plist>
